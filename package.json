{
  "name": "seismic-sentry",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/api",
    "infra",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @seismic-sentry/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "cdk": "npm run cdk -w @seismic-sentry/infra",
    "cdk:synth": "npm run synth -w @seismic-sentry/infra",
    "cdk:deploy": "npm run deploy -w @seismic-sentry/infra",
    "import:fixtures": "npm run import:fixtures -w @seismic-sentry/api",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
