      "parameters": {
        "duration": "PT2M"
      },
      "targets": {
        "Functions": "ApiLambda"
      }
    }
  },
  "stopConditions": [
    {
      "source": "none"
    }
  ],
  "roleArn": "REPLACE_WITH_FIS_ROLE_ARN",
  "tags": {
    "Project": "SeismicSentry",
    "Purpose": "Hackathon resilience demo"
  }
}
