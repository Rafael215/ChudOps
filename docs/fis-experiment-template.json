{
  "description": "SeismicSentry hackathon chaos template placeholder",
  "targets": {
    "ApiLambda": {
      "resourceType": "aws:lambda:function",
      "resourceArns": ["REPLACE_WITH_SCENARIO_ORCHESTRATOR_FUNCTION_ARN"],
      "selectionMode": "ALL"
    }
  },
  "actions": {
